# Copier vers .env.docker : cp .env.docker.example .env.docker
# Puis : docker compose --env-file .env.docker up -d --build

# --- HTTP ---
HTTP_PORT=8080

# --- Laravel (obligatoire en prod : fixer APP_KEY une fois) ---
# Générer : docker compose run --rm app php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Domaine(s) pour Sanctum / cookies (séparés par virgules, sans https://)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# --- MySQL (doit correspondre au service db) ---
DB_DATABASE=lab_btp
DB_USERNAME=labbtp
DB_PASSWORD=labbtp_secret
DB_ROOT_PASSWORD=root_secret_change_me

# --- Conteneur app ---
RUN_OPTIMIZE=1
# Mettre à 1 une seule fois pour charger les comptes démo (admin@lab.local / password)
RUN_SEED=0
