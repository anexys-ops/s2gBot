# Copier à la racine du dépôt : cp docker/env.docker.example .env.docker
# Puis : docker compose --env-file .env.docker up -d --build
#
# IMPORTANT — Docker vs hôte :
#   L’app qui tourne dans les conteneurs lit UNIQUEMENT .env.docker (injecté dans « app »).
#   Les commandes Artisan pour cette app : ./scripts/docker-artisan.sh …
#   Ne pas confondre avec /var/www/s2gBot/laravel-api/.env + php-fpm sur l’hôte (autre déploiement).

# --- HTTP (port publié sur la machine hôte → conteneur web:80) ---
HTTP_PORT=8080
# Exemple serveur avec UI sur le port 167 :
# HTTP_PORT=167
# APP_URL / FRONTEND_URL / SANCTUM doivent utiliser la même origine que le navigateur (IP ou nom + port).

# --- Laravel (recommandé : fixer APP_KEY en prod) ---
# Générer : docker compose run --rm app php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
# Exemple accès public http://IP:167 (même machine que curl ifconfig.me) :
# APP_URL=http://86.104.252.67:167
# FRONTEND_URL=http://86.104.252.67:167
# SANCTUM_STATEFUL_DOMAINS=86.104.252.67,86.104.252.67:167

# Domaine(s) Sanctum (sans schéma), séparés par des virgules
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# --- MySQL (service « db » dans docker-compose) ---
DB_DATABASE=lab_btp
DB_USERNAME=labbtp
DB_PASSWORD=labbtp_secret
DB_ROOT_PASSWORD=root_secret_change_me

# Port MySQL publié sur l’hôte, écoute 127.0.0.1 uniquement (sauvegarde, mysql client, tunnel SSH).
# L’API dans le conteneur « app » utilise DB_HOST=db (réseau Docker), pas ce port.
MYSQL_PUBLISH_PORT=33060

# --- Conteneur app ---
RUN_OPTIMIZE=1
RUN_SEED=0
