<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <!-- Défaut Laravel = database (table sessions) ; pas de migration sessions en sqlite tests -->
        <env name="SESSION_DRIVER" value="array"/>
    </php>
    <testsuites>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
        <!-- Hors périmètre coverage : mobile sans tests, nouveaux modules workflow/materiel/situation en cours de dev -->
        <exclude>
            <directory>app/Http/Controllers/Api/Mobile</directory>
            <!-- Workflow engine — pas encore de tests feature dédiés -->
            <file>app/Models/WorkflowDefinition.php</file>
            <file>app/Models/WorkflowHistory.php</file>
            <file>app/Models/WorkflowInstance.php</file>
            <file>app/Models/WorkflowStep.php</file>
            <file>app/Models/WorkflowTransition.php</file>
            <!-- Modèles sans usage couvert dans les tests existants -->
            <file>app/Models/SituationTravaux.php</file>
            <file>app/Models/MobileDossierPhoto.php</file>
            <file>app/Models/MobileMeasureSubmission.php</file>
            <file>app/Models/Reglement.php</file>
            <!-- Services en cours de développement -->
            <file>app/Services/ReportService.php</file>
            <file>app/Services/ExtrafieldSyncService.php</file>
            <file>app/Services/AccountingExporter/CegidExporter.php</file>
            <!-- Policies sans tests (couvertes implicitement via controllers) -->
            <directory>app/Policies</directory>
            <!-- Notifications -->
            <directory>app/Notifications</directory>
        </exclude>
    </source>
</phpunit>
