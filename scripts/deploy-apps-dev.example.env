# Copier : cp scripts/deploy-apps-dev.example.env deploy.env
# Puis éditer deploy.env (nano, Cursor, etc.) — OBLIGATOIRE : remplacer DEPLOY_HOST par la vraie valeur.
#
# Lancer le déploiement (une seule ligne, sans copier les commentaires # ci-dessus) :
#   set -a && source deploy.env && set +a && ./scripts/deploy-apps-dev.sh
#
# Le script build le front en local, rsync tout le dépôt (apps/, scripts/, .github/, docs, sources, etc.),
# puis copie dist/ dans laravel-api/public/, puis composer + migrations sur le serveur.
# Les dossiers sensibles déjà sur le serveur sont préservés : laravel-api/.env, storage/, bootstrap/cache/.
#
# Exclus du rsync (réinstallés sur le serveur si besoin) : node_modules/, laravel-api/vendor/, deploy.env, .cursor/
# Optionnel : DEPLOY_SYNC_GIT=1 pour inclure aussi .git/ (copie intégrale du dépôt Git).
#
# Serveur de tests : DEPLOY_FOR_TESTS=1 → APP_ENV=staging, APP_DEBUG=true, composer avec paquets dev,
# pas de config/route/view cache (itération plus simple).

# Remplacez par l’IP ou le hostname SSH réel (PAS example.com — réservé à la documentation)
DEPLOY_HOST=REMPLACER_PAR_IP_OU_HOSTNAME
# Port SSH (22 par défaut ; ex. 167 si le serveur écoute ailleurs)
DEPLOY_PORT=22
DEPLOY_USER=deploy
# Répertoire cible sur le serveur (créé automatiquement) : tout le projet y est copié puis mis à jour.
REMOTE_PATH=/var/www/s2gBot
# REMOTE_PATH=/var/www/s2gBot-test   # autre instance pour tests isolés

# Domaine public HTTPS (APP_URL / FRONTEND_URL / Sanctum)
DEPLOY_PUBLIC_DOMAIN=s2g.apps-dev.fr
# Base de données sur le serveur : mariadb (défaut) ou pgsql
DEPLOY_DB_ENGINE=mariadb

# DEPLOY_FOR_TESTS=1
# DEPLOY_SYNC_GIT=1
# Nginx : par défaut le déploiement réécrit le vhost (ssl_stapling off, SPA + /api). Désactiver : DEPLOY_NGINX_ENSURE=0
#
# Si https://domaine reste vide alors que le déploiement est OK : souvent une box NAT ou un proxy
# redirige le port 80 vers HTTPS sans ouvrir/transférer le 443 vers la VM. Corriger le pare-feu / NAT
# (443 → serveur) ou désactiver la redirection HTTPS sur la box, puis relancer server-ensure-nginx-debian.sh.
# HTTP seul sur la VM (tests) : sur le serveur, NGINX_HTTP_ONLY=1 bash …/server-ensure-nginx-debian.sh …

# Clé SSH (si pas d’agent) :
# export SSH_IDENTITY_FILE=~/.ssh/id_ed25519_prod

# Sur le serveur : créer laravel-api/.env (APP_KEY, APP_URL, DB_*, FRONTEND_URL = URL publique du site)
# avant la première exécution.
