# Copier vers deploy.env (non versionné) et adapter.
# Usage : set -a && source deploy.env && set +a && ./scripts/deploy-apps-dev.sh

# Production actuelle : reverse-proxy + PHP sur 86.104.252.67 (SSH port 22).
DEPLOY_HOST=86.104.252.67
DEPLOY_PORT=22
DEPLOY_USER=root
REMOTE_PATH=/var/www/s2gBot

# Clé SSH (obligatoire si pas d’agent) — ex. machine de déploiement avec ~/.ssh/id_claudecode
# export SSH_IDENTITY_FILE=~/.ssh/id_claudecode

# Sur le serveur : composer install utilise parfois --ignore-platform-reqs tant que PHP < 8.4
# (voir script ou lancer PHP 8.4 quand disponible dans les dépôts).
